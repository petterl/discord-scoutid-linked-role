# Discord Configuration
discord_token         = "YOUR_DISCORD_TOKEN"
discord_client_id     = "YOUR_DISCORD_CLIENT_ID"
discord_client_secret = "YOUR_DISCORD_CLIENT_SECRET"
discord_public_key    = "YOUR_DISCORD_PUBLIC_KEY"
discord_guild_id      = "YOUR_DISCORD_GUILD_ID"

# ScoutID Configuration
scoutid_client_id     = "YOUR_SCOUTID_CLIENT_ID"
scoutid_client_secret = "YOUR_SCOUTID_CLIENT_SECRET"

# Application Configuration
cookie_secret = "GENERATE_A_RANDOM_SECRET_HERE"

# ScoutNet Configuration
scoutnet_event_id            = "YOUR_EVENT_ID"
scoutnet_participants_apikey = "YOUR_PARTICIPANTS_API_KEY"

# Role Configuration (optional - defaults shown)
scoutnet_scout_role    = "scout"
scoutnet_event_role    = "participant"
scoutnet_fee_roles     = "25694:deltagare,27561:deltagare,25696:ist,25702:IST-Direktresa,33293:ledare,34850:ledare,25697:cmt,25693:cmt"
scoutnet_division_roles = "deltagare:88168:Deltagare-{div}:Deltagare-Väntande,ist:88168:IST-Patrull-{div}:IST-Väntande,ledare:107592:Ledare-{div}:Ledare-Väntande"
